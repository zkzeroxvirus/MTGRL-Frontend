# Production Discord OAuth example.
# Copy this to your server's private env file and fill in the real values.

PUBLIC_BASE_URL=https://www.mtginfo.org
DISCORD_REDIRECT_URI=https://www.mtginfo.org/auth/discord/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

DISCORD_GUILD_ID=
DISCORD_HOST_ROLE_ID=

# Use a long random value. Do not reuse the dev secret.
SESSION_SECRET=
