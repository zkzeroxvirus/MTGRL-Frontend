# Production Discord OAuth example.
# Copy this to your server's private env file and fill in the real values.

PUBLIC_BASE_URL=https://www.mtginfo.org
DISCORD_REDIRECT_URI=https://www.mtginfo.org/auth/discord/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

DISCORD_GUILD_ID=
DISCORD_HOST_ROLE_ID=
DISCORD_PLAYER_ROLE_ID=
DISCORD_ADMIN_ROLE_ID=
DISCORD_MOD_ROLE_ID=

# Bot token used to sync Discord server members for player autocomplete.
# The bot must be in your server. Enable Server Members Intent if Discord requires it.
DISCORD_BOT_TOKEN=
DISCORD_REVIEW_CHANNEL_ID=

# Use a long random value. Do not reuse the dev secret.
SESSION_SECRET=
