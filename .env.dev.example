# Copy this file to .env for local OAuth testing with docker-compose.dev.yml.

PUBLIC_BASE_URL=http://localhost:8080
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

DISCORD_GUILD_ID=
DISCORD_HOST_ROLE_ID=
DISCORD_PLAYER_ROLE_ID=

# Bot token used to sync Discord server members for player autocomplete.
# The bot must be in your server. Enable Server Members Intent if Discord requires it.
DISCORD_BOT_TOKEN=

SESSION_SECRET=change-this-to-a-long-random-dev-secret
